NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/terravio

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:5173

TERRAVIO_BACKEND_BASE_URL=
TERRAVIO_API_KEY=

# Property valuation provider
RENTCAST_API_KEY=

# Privy (@privy-io/node) — app id + secret from dashboard
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional overrides:
# PRIVY_API_BASE_URL=https://api.privy.io
# PRIVY_JWT_VERIFICATION_KEY=

# Optional: skip Privy on /api/users/me when NODE_ENV=development
DEV_SKIP_AUTH=false

# Base Sepolia
CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org

# Deployed RWA proxies (see Contract/deployment-output/baseSepolia_addresses.json)
GOLD_TOKEN_ADDRESS=your_gold_address_from_the deployed_smart_contract
PROPERTY_TOKEN_ADDRESS=your_property_address_from_the deployed_smart_contract
CARBON_TOKEN_ADDRESS=your_carbon_address_from_the deployed_smart_contract

# KYC manager key (same role as Hardhat named account kycManager) — keep offline in prod
KYC_MANAGER_PRIVATE_KEY=

# Didit — from Console → API & Webhooks
DIDIT_APP_ID=
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
DIDIT_WORKFLOW_ID=
# DIDIT_API_BASE_URL=https://verification.didit.me
