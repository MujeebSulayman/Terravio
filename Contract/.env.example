# Terravio — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Wallet ─────────────────────────────────────────────────────────────────────
# The private key of the deployer wallet (without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ── RPC URLs ───────────────────────────────────────────────────────────────────
# Get from Alchemy (https://www.alchemy.com) or Infura (https://infura.io)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Block Explorer ─────────────────────────────────────────────────────────────
# For contract verification on Basescan
BASESCAN_API_KEY=your_basescan_api_key

# ── Chainlink Functions ────────────────────────────────────────────────────────
# Created at https://functions.chain.link
CHAINLINK_SUBSCRIPTION_ID=your_subscription_id

# ── Off-Chain Data APIs ────────────────────────────────────────────────────────
# RealtyMole — property valuations
REALTYMOLE_API_KEY=your_realtymole_key

# Terravio Backend — your own API
TERRAVIO_API_KEY=your_internal_api_key

# ── Gas Reporter ───────────────────────────────────────────────────────────────
CMC_API_KEY=your_coinmarketcap_key
REPORT_GAS=false
